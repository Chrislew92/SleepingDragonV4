<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dragon_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="serif"
        android:text="@string/app_name"
        android:textColor="@color/dragon_gold"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/subtitle"
        android:textColor="@color/dragon_muted"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/micStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/mic_waiting"
        android:textColor="@color/dragon_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/partialText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:minHeight="24dp"
        android:textColor="@color/dragon_gold"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/storyText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:text="@string/hint"
        android:textColor="@color/dragon_text"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/xpText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/dragon_muted"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/fairyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/dragon_gold"
        android:textSize="11sp"
        android:textStyle="italic" />

    <Button
        android:id="@+id/listenButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/dragon_gold"
        android:text="@string/listen_button"
        android:textColor="@color/dragon_bg" />

    <Button
        android:id="@+id/resetButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/reset_button"
        android:textColor="@color/dragon_muted" />

</LinearLayout>